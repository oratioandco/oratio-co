---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = new URL(Astro.request.url).pathname.replace(base, '') || '/';
---

<nav class="nav">
  <div class="nav-container">
    <a href={`${base}/`} class="logo">Oratio&Co</a>
    <ul class="nav-links">
      <li><a href={`${base}/`} class={currentPath === '/' ? 'active' : ''}>Home</a></li>
      <li><a href={`${base}/missional-by-design`} class={currentPath === '/missional-by-design' ? 'active' : ''}>Missional by Design</a></li>
      <li><a href="https://missional.design/ministry-model-canvas" target="_blank" rel="noopener noreferrer">
        Ministry Model Canvas
        <span class="sr-only"> (external)</span>
        <svg class="nav-external" aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
      </a></li>
      <li><a href={`${base}/about`} class={currentPath === '/about' ? 'active' : ''}>About</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    background: rgba(246, 241, 231, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(10, 26, 42, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.1rem 6vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 140, 'opsz' 14;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: #0a1a2a;
    text-decoration: none;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2.25rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 120, 'opsz' 14;
    font-size: 0.9rem;
    font-weight: 500;
    color: #0a1a2a;
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .nav-links a:hover {
    opacity: 1;
  }

  .nav-links a.active {
    opacity: 1;
    font-weight: 700;
  }

  .nav-external {
    display: inline-block;
    margin-left: 0.25rem;
    vertical-align: -1px;
    opacity: 0.6;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-links {
      gap: 1rem;
      font-size: 0.85rem;
    }
  }
</style>
