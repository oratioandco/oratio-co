---
import LangSwitch from './LangSwitch.astro';
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const prefix = lang === 'de' ? `${base}/de` : base;
const currentPath = new URL(Astro.request.url).pathname;

function isActive(href: string): boolean {
  const p = currentPath.replace(/\/$/, '');
  const h = href.replace(/\/$/, '');
  if (h === (base || '') && (p === '' || p === base)) return true;
  if (h === `${base}/de` && (p === `${base}/de` || p === `${base}/de/`)) return true;
  return p === h;
}
---

<nav class="nav" aria-label={lang === 'de' ? 'Hauptnavigation' : 'Primary'} data-nav-open="false">
  <div class="nav-container">
    <a href={`${prefix}/`} class="logo">Oratio&amp;Co</a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label={lang === 'de' ? 'Menü umschalten' : 'Toggle menu'}>
      <svg class="icon-menu" aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      <svg class="icon-close" aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>

    <div class="nav-menu" id="nav-menu">
      <ul class="nav-links">
        <li>
          <a href={`${prefix}/`} class={isActive(`${prefix}/`) ? 'active' : ''}>
            {t(lang, 'nav.home')}
          </a>
        </li>
        <li>
          <a href={`${prefix}/missional-by-design`} class={isActive(`${prefix}/missional-by-design`) ? 'active' : ''}>
            {t(lang, 'nav.missionalByDesign')}
          </a>
        </li>
        <li>
          <a href={lang === 'de' ? 'https://missional.design/de/ministry-model-canvas' : 'https://missional.design/ministry-model-canvas'} target="_blank" rel="noopener noreferrer">
            {t(lang, 'nav.ministryModelCanvas')}
            <span class="sr-only"> {t(lang, 'common.external')}</span>
            <svg class="nav-external" aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8"/></svg>
          </a>
        </li>
        <li>
          <a href={`${prefix}/about`} class={isActive(`${prefix}/about`) ? 'active' : ''}>
            {t(lang, 'nav.about')}
          </a>
        </li>
      </ul>
      <LangSwitch currentLocale={lang} />
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const nav = document.querySelector('.nav');
    if (!nav) return;
    const btn = nav.querySelector('.nav-toggle');
    const menu = nav.querySelector('.nav-menu');
    if (!btn || !menu) return;

    function setOpen(open) {
      nav.setAttribute('data-nav-open', open ? 'true' : 'false');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) document.body.style.overflow = 'hidden';
      else document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      const open = nav.getAttribute('data-nav-open') === 'true';
      setOpen(!open);
    });

    // Close when a menu link is activated (mobile)
    menu.addEventListener('click', (e) => {
      if (e.target.closest('a')) setOpen(false);
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.getAttribute('data-nav-open') === 'true') {
        setOpen(false);
        btn.focus();
      }
    });

    // Reset on resize to desktop
    const mq = window.matchMedia('(min-width: 720px)');
    mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
  })();
</script>

<style>
  .nav {
    background: rgba(246, 241, 231, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(10, 26, 42, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.1rem 6vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .logo {
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 140, 'opsz' 14;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: #0a1a2a;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* ── Hamburger toggle ── */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: 0.5rem;
    margin: -0.5rem;
    cursor: pointer;
    color: #0a1a2a;
    line-height: 0;
    border-radius: 4px;
  }
  .nav-toggle:hover { background: rgba(10,26,42,0.06); }
  .nav-toggle .icon-close { display: none; }
  .nav[data-nav-open="true"] .icon-menu { display: none; }
  .nav[data-nav-open="true"] .icon-close { display: inline; }

  /* ── Menu (desktop: inline; mobile: overlay) ── */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 2.25rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2.25rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 120, 'opsz' 14;
    font-size: 0.9rem;
    font-weight: 500;
    color: #0a1a2a;
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .nav-links a:hover { opacity: 1; }
  .nav-links a.active { opacity: 1; font-weight: 700; }

  .nav-external {
    display: inline-block;
    margin-left: 0.25rem;
    vertical-align: -1px;
    opacity: 0.6;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Mobile: hamburger + slide-down panel ── */
  @media (max-width: 719px) {
    .nav-toggle { display: inline-flex; align-items: center; }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(246, 241, 231, 0.98);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      flex-direction: column;
      align-items: flex-start;
      gap: 1.75rem;
      padding: 2rem 6vw 2.5rem;
      border-bottom: 1px solid rgba(10, 26, 42, 0.08);
      visibility: hidden;
      opacity: 0;
      transform: translateY(-8px);
      transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
    }

    .nav[data-nav-open="true"] .nav-menu {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
    }

    .nav-links {
      flex-direction: column;
      gap: 1.25rem;
      width: 100%;
    }
    .nav-links a {
      font-size: 1.1rem;
      font-variation-settings: 'wdth' 130, 'opsz' 18;
      opacity: 0.9;
    }
  }
</style>
