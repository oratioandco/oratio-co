---
import { altLocalePath, type Locale } from '../i18n/ui';

interface Props {
  currentLocale: Locale;
}

const { currentLocale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = new URL(Astro.request.url).pathname;

const enHref = altLocalePath(pathname, 'en', base);
const deHref = altLocalePath(pathname, 'de', base);
---

<div class="lang-switch" role="group" aria-label="Language">
  <a
    href={enHref}
    lang="en"
    aria-current={currentLocale === 'en' ? 'true' : undefined}
    class={currentLocale === 'en' ? 'active' : ''}
  >EN</a>
  <span class="divider" aria-hidden="true">/</span>
  <a
    href={deHref}
    lang="de"
    aria-current={currentLocale === 'de' ? 'true' : undefined}
    class={currentLocale === 'de' ? 'active' : ''}
  >DE</a>
</div>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 120, 'opsz' 14;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
  }
  .lang-switch a {
    color: inherit;
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 150ms ease;
    padding: 0.25em 0;
  }
  .lang-switch a:hover { opacity: 0.85; }
  .lang-switch a.active {
    opacity: 1;
  }
  .lang-switch .divider {
    opacity: 0.3;
  }
</style>
