---
import EmailLink from './EmailLink.astro';
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Legal pages are bilingual already (German first, English section below) — same URL for both locales
const impressumHref = `${base}/impressum`;
const datenschutzHref = `${base}/datenschutz`;
const barrierefreiheitHref = `${base}/barrierefreiheit`;
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-main">
      <p class="footer-text">{t(lang, 'footer.tagline')} &nbsp;|&nbsp; <EmailLink /></p>
      <div class="footer-links">
        <a href="https://missional.design" target="_blank" rel="noopener noreferrer">missional.design</a>
        <span class="separator">•</span>
        <a href="https://aperto.bible" target="_blank" rel="noopener noreferrer">aperto.bible</a>
      </div>
    </div>
    <div class="footer-legal">
      <a href={impressumHref}>{t(lang, 'footer.links.imprint')}</a>
      <span class="separator">•</span>
      <a href={datenschutzHref}>{t(lang, 'footer.links.privacy')}</a>
      <span class="separator">•</span>
      <a href={barrierefreiheitHref}>{t(lang, 'footer.links.accessibility')}</a>
    </div>
    <p class="footer-credit">{t(lang, 'footer.credit')}</p>
  </div>
</footer>

<style>
  .footer {
    background: #0a1a2a;
    color: #f6f1e7;
    padding: clamp(3rem, 8vh, 5rem) 6vw;
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 110, 'opsz' 14;
  }

  .footer-content {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-main {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(246, 241, 231, 0.15);
  }

  .footer-text {
    font-family: 'Roboto Flex', 'Inter', sans-serif;
    font-variation-settings: 'wdth' 120, 'opsz' 14;
    font-size: 0.95rem;
    color: rgba(246, 241, 231, 0.85);
    margin: 0 0 0.75rem 0;
  }

  .footer-text a,
  .footer-links a,
  .footer-legal a {
    color: #f6f1e7;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.2s ease;
  }

  .footer-text a:hover,
  .footer-links a:hover,
  .footer-legal a:hover { opacity: 0.6; }

  .footer-links {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .footer-legal {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: rgba(246, 241, 231, 0.6);
    letter-spacing: 0.04em;
  }

  .separator {
    color: rgba(246, 241, 231, 0.3);
    margin: 0 0.5rem;
  }

  .footer-credit {
    font-size: 0.8rem;
    color: rgba(246, 241, 231, 0.5);
    text-align: center;
    margin: 1.5rem 0 0 0;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 2.5rem 6vw;
    }
  }
</style>
