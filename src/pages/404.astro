---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist">


  <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div style="text-align: center; max-width: 600px;">
      <h1 style="font-size: 4rem; margin-bottom: 1rem;">404</h1>
      <h2 style="margin-bottom: 1rem;">Page Not Found</h2>
      <p style="color: var(--color-gray); font-size: 1.1rem; margin-bottom: 2rem;">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" style="display: inline-block; padding: 0.75rem 2rem; background: var(--color-blue); color: white; border-radius: 4px; text-decoration: none; font-weight: 600; transition: background 0.2s ease;">
        Go Home
      </a>
    </div>
  </section>


</BaseLayout>
