---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Oratio&Co - Prayer & Innovation" description="Equipping churches and organizations to navigate fluid contexts through strategic design, theological reflection, and innovation">
  <Nav />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <svg id="church" class="hero-svg" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
        <image href="/church.svg" width="500" height="500" />
      </svg>
      <h1 class="hero-title">Oratio&Co</h1>
      <p class="hero-tagline">prayer & innovation</p>
      <p class="hero-subtitle">Equipping churches and organizations to navigate fluid contexts through strategic design, theological reflection, and innovation</p>
    </div>
  </section>

  <!-- The Oratio&Co Method Section -->
  <section class="section section-light">
    <div class="container">
      <h2 class="text-center">The Oratio&Co Method</h2>
      <p class="text-center text-muted">Four pillars guiding our approach to ministry and organizational transformation</p>

      <div class="pillar-grid">
        <div class="pillar">
          <h3>Context Humility</h3>
          <p>Understanding the cultural context before acting. Every ministry operates within a specific context that shapes how the gospel is received.</p>
        </div>
        <div class="pillar">
          <h3>Design Thinking</h3>
          <p>Applying human-centered design principles to ministry challenges. Starting with empathy, prototyping solutions, and iterating based on feedback.</p>
        </div>
        <div class="pillar">
          <h3>Collaborative Team Work</h3>
          <p>Drawing on diverse gifts and perspectives within the body of Christ. Participatory leadership that empowers rather than controls.</p>
        </div>
        <div class="pillar">
          <h3>Psychological Safety</h3>
          <p>Creating environments where people can take risks, admit mistakes, and grow without fear of judgment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">What We Do</h2>
      <p class="text-center text-muted">Strategic design and ministry consulting for flourishing communities</p>

      <div style="margin-top: 2rem; font-size: 1.05rem; line-height: 1.8; color: var(--color-gray); max-width: 700px; margin-left: auto; margin-right: auto;">
        <ul style="list-style: none; padding: 0;">
          <li style="margin-bottom: 1.25rem;">
            <strong style="color: var(--color-dark); font-family: 'Inter', sans-serif;">Ministry consulting and strategic design</strong> — helping churches clarify their mission and operationalize their vision
          </li>
          <li style="margin-bottom: 1.25rem;">
            <strong style="color: var(--color-dark); font-family: 'Inter', sans-serif;"><a href="/ministry-model-canvas">The Ministry Model Canvas</a></strong> — a strategic planning tool adapted from the Business Model Canvas
          </li>
          <li style="margin-bottom: 1.25rem;">
            <strong style="color: var(--color-dark); font-family: 'Inter', sans-serif;"><a href="https://missional.design" target="_blank" rel="noopener noreferrer">Missional Product Design</a></strong> — building digital tools that foster spiritual formation and community
          </li>
          <li style="margin-bottom: 1.25rem;">
            <strong style="color: var(--color-dark); font-family: 'Inter', sans-serif;"><a href="https://aperto.bible" target="_blank" rel="noopener noreferrer">Building Aperto</a></strong> — digital spiritual formation resources for the global church
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Featured Work / Resources Section -->
  <section class="section section-light">
    <div class="container">
      <h2 class="text-center">Featured Work</h2>

      <div class="card-grid">
        <div class="card">
          <h3 class="card-title">Missional by Design</h3>
          <p>Growing flourishing ministries in fluid contexts. A transformational approach to church leadership combining strategic thinking, responsible stewardship, and participatory operations.</p>
          <a href="/missional-by-design" class="card-link">Learn more →</a>
        </div>

        <div class="card">
          <h3 class="card-title">Ministry Model Canvas</h3>
          <p>A strategic planning tool adapted from the Business Model Canvas. Nine blocks to help churches clarify their ministry model and navigate change.</p>
          <a href="/ministry-model-canvas" class="card-link">Explore the canvas →</a>
        </div>

        <div class="card">
          <h3 class="card-title">Missional Product Design Framework</h3>
          <p>Nine principles for building formation technology that honors the sacred and the human. Designing digital products that serve the spiritual formation of communities.</p>
          <a href="https://missional.design" target="_blank" rel="noopener noreferrer" class="card-link">Visit missional.design →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  /* Override some global styles for this page */
</style>
