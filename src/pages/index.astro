---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Inline the church SVG so stroke animation applies to its inner paths
const churchSvg = fs.readFileSync(
  path.resolve('./public/church.svg'),
  'utf-8'
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Oratio&Co - Prayer & Innovation" description="Equipping churches and organizations to navigate fluid contexts through strategic design, theological reflection, and innovation">


  <!-- Hero Section - left/right split with large SVG -->
  <section class="hero" aria-label="Welcome">
    <div class="hero-svg-side" aria-hidden="true">
      <div class="hero-svg-wrap" role="presentation" set:html={churchSvg}></div>
    </div>
    <div class="hero-text-side">
      <p class="hero-tagline">prayer &amp; innovation</p>
      <h1 class="hero-title">Oratio&amp;Co</h1>
      <p class="hero-subtitle">
        Equipping churches and organizations to navigate fluid contexts through strategic design, theological
        reflection, and innovation.
      </p>
    </div>
  </section>

  <!-- The Oratio&Co Method Section -->
  <section class="section section-light">
    <div class="container">
      <h2 class="text-center">The Oratio&Co Method</h2>
      <p class="text-center text-muted">Four pillars guiding our approach to ministry and organizational transformation</p>

      <div class="pillar-grid">
        <div class="pillar">
          <h3>Context Humility</h3>
          <p>Understanding the cultural context before acting. Every ministry operates within a specific context that shapes how the gospel is received.</p>
        </div>
        <div class="pillar">
          <h3>Design Thinking</h3>
          <p>Applying human-centered design principles to ministry challenges. Starting with empathy, prototyping solutions, and iterating based on feedback.</p>
        </div>
        <div class="pillar">
          <h3>Collaborative Team Work</h3>
          <p>Drawing on diverse gifts and perspectives within the body of Christ. Participatory leadership that empowers rather than controls.</p>
        </div>
        <div class="pillar">
          <h3>Psychological Safety</h3>
          <p>Creating environments where people can take risks, admit mistakes, and grow without fear of judgment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">How We Work With You</h2>
      <p class="text-center text-muted">Four ways to bring Oratio&amp;Co into your ministry or team</p>

      <div class="card-grid">
        <div class="card">
          <div class="card-num">01</div>
          <h3 class="card-title">Ministry Consultation</h3>
          <p>Personalized consultation to help your church or ministry navigate cultural shifts, clarify your missional identity, and design effective witness in fluid contexts. Typically 4–8 sessions, in-person or remote.</p>
        </div>

        <div class="card">
          <div class="card-num">02</div>
          <h3 class="card-title">Canvas Workshop Facilitation</h3>
          <p>We run a facilitated Ministry Model Canvas session with your team — half-day or full-day format. You leave with a shared strategic artifact and a plan for what to prototype next.</p>
        </div>

        <div class="card">
          <div class="card-num">03</div>
          <h3 class="card-title">Innovation Training</h3>
          <p>Workshops for ministry teams on applied design thinking, rapid prototyping, user research for churches, and formation-centered product development.</p>
        </div>

        <div class="card">
          <div class="card-num">04</div>
          <h3 class="card-title">Online Innovation Cohort</h3>
          <p>Join a small cohort of ministry innovators working through the frameworks together — peer learning, structured exercises, and expert guidance over 8 weeks.</p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href={`${base}/about`} class="cta-button">Get in touch →</a>
      </div>
    </div>
  </section>

  <!-- Frameworks We Use Section -->
  <section class="section section-light">
    <div class="container">
      <h2 class="text-center">The Frameworks We Use</h2>
      <p class="text-center text-muted">
        Our consulting draws on a body of open-source frameworks published at
        <a href="https://missional.design" target="_blank" rel="noopener noreferrer">missional.design</a>.
        Read them, use them freely — or bring us in to help apply them to your context.
      </p>

      <div class="card-grid">
        <div class="card">
          <h3 class="card-title">Missional by Design</h3>
          <p>The underlying approach. A transformational framework for church leadership combining strategic thinking, stewardship, and participatory operations.</p>
          <a href={`${base}/missional-by-design`} class="card-link">Read the approach →</a>
        </div>

        <div class="card">
          <h3 class="card-title">Ministry Model Canvas</h3>
          <p>A nine-block strategic planning framework adapted from the Business Model Canvas. For clarifying target audience, missional identity, and effectiveness.</p>
          <a href="https://missional.design/ministry-model-canvas" target="_blank" rel="noopener noreferrer" class="card-link">Explore the canvas ↗</a>
        </div>

        <div class="card">
          <h3 class="card-title">Missional Product Design</h3>
          <p>Nine principles and six diagnostic questions for building digital tools that serve spiritual formation rather than engagement optimization.</p>
          <a href="https://missional.design/framework" target="_blank" rel="noopener noreferrer" class="card-link">Read the framework ↗</a>
        </div>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  /* 3D stage for the church SVG — extruded, tilted, dimensional */
  .hero-svg-wrap {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    transform-style: preserve-3d;
    transform:
      rotateY(-14deg)
      rotateX(6deg)
      rotateZ(-1deg);
    transition: transform 600ms cubic-bezier(.2, .8, .2, 1);
    animation: floatGently 14s ease-in-out infinite alternate;
  }

  /* Gentle breathing tilt so it feels alive */
  @keyframes floatGently {
    from { transform: rotateY(-14deg) rotateX(6deg) rotateZ(-1deg) translateY(0); }
    to   { transform: rotateY(-10deg) rotateX(4deg) rotateZ( 1deg) translateY(-8px); }
  }

  .hero-svg-wrap :global(svg) {
    width: 100%;
    height: auto;
    max-height: 85vh;
    display: block;
    position: relative;
    z-index: 5;
    /* Extruded depth — stacked drop-shadows create layered parallax copies */
    filter:
      drop-shadow( 1px  1px 0 rgba(131, 201, 236, 0.55))
      drop-shadow( 3px  3px 0 rgba(131, 201, 236, 0.45))
      drop-shadow( 6px  6px 0 rgba(240, 231, 148, 0.50))
      drop-shadow( 9px  9px 0 rgba(240, 231, 148, 0.40))
      drop-shadow(12px 12px 0 rgba(255, 255, 255, 0.35))
      drop-shadow(18px 18px 32px rgba(0, 0, 0, 0.18));
  }

  /* Scale back on small screens, drop perspective */
  @media (max-width: 900px) {
    .hero-svg-wrap {
      transform: rotateY(-8deg) rotateX(3deg);
      animation: none;
    }
    .hero-svg-wrap :global(svg) {
      max-height: 50vh;
      max-width: 400px;
      filter:
        drop-shadow( 2px 2px 0 rgba(131, 201, 236, 0.5))
        drop-shadow( 5px 5px 0 rgba(240, 231, 148, 0.4))
        drop-shadow( 8px 8px 20px rgba(0,0,0,0.15));
    }
  }

  /* User preference — don't animate if reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-svg-wrap {
      animation: none;
    }
  }
</style>
