---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Oratio&Co — Strategic design for ministries"
  description="A strategic design consultancy for churches, ministries, and faith-driven teams navigating fluid contexts."
>
  <!-- ═════════ HERO ═════════ -->
  <section class="hero" aria-label="Welcome">
    <!-- Procedural WebGL-style wireframe rendered in Canvas 2D (no library) -->
    <canvas class="hero-canvas" id="hero-canvas" aria-hidden="true" role="presentation"></canvas>

    <div class="hero-meta" aria-hidden="true">
      <span>Strategic Design <span class="dot"></span> Ministry Innovation</span>
    </div>

    <div class="hero-content">
      <p class="hero-tagline">Oratio&amp;Co</p>
      <h1 class="hero-title">Ministry<br/>by design.</h1>
      <p class="hero-subtitle">
        Strategic design and innovation consulting for churches, ministries, and faith-driven teams.
      </p>
    </div>
  </section>

  <script is:inline>
    // ─── Procedural 3D wireframe orb, Canvas 2D, no dependencies ───
    (function () {
      const canvas = document.getElementById('hero-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d', { alpha: true });

      // Palette (matches site CSS variables)
      const COLOR_CREAM = 'rgba(246, 241, 231, 1)';
      const COLOR_GOLD  = 'rgba(240, 231, 148, 1)';
      const COLOR_BLUE  = 'rgba(131, 201, 236, 1)';

      // ── Points on a sphere via Fibonacci lattice (even distribution) ──
      const N_POINTS = 96;
      const SPHERE_RADIUS = 1; // in normalized units; scaled at draw time
      const points = [];
      const GOLDEN_RATIO = (1 + Math.sqrt(5)) / 2;
      for (let i = 0; i < N_POINTS; i++) {
        const t = i / (N_POINTS - 1);
        const inclination = Math.acos(1 - 2 * t);
        const azimuth = 2 * Math.PI * i / GOLDEN_RATIO;
        points.push({
          x: Math.sin(inclination) * Math.cos(azimuth),
          y: Math.sin(inclination) * Math.sin(azimuth),
          z: Math.cos(inclination),
          // deterministic accent: every 13th point gets a gold hue
          accent: i % 13 === 0,
        });
      }

      // ── Precompute candidate connections ──
      // Each point connects to its nearest 6 neighbors. Each connection has its own
      // period + phase, so they pulse (grow → hold → fade → dormant) on staggered
      // schedules. At any moment some edges are building, some dissolving —
      // a network in constant reconfiguration.
      const connections = [];
      const seen = new Set();
      for (let i = 0; i < points.length; i++) {
        const dists = [];
        for (let j = 0; j < points.length; j++) {
          if (i === j) continue;
          const dx = points[i].x - points[j].x;
          const dy = points[i].y - points[j].y;
          const dz = points[i].z - points[j].z;
          dists.push({ j, d: dx*dx + dy*dy + dz*dz });
        }
        dists.sort((a, b) => a.d - b.d);
        for (let k = 0; k < 6; k++) {
          const j = dists[k].j;
          const key = i < j ? `${i}_${j}` : `${j}_${i}`;
          if (seen.has(key)) continue;
          seen.add(key);
          connections.push({
            i: Math.min(i, j),
            j: Math.max(i, j),
            phase:  Math.random() * Math.PI * 2,
            // period in seconds — most cycles land between 8 and 22s for a calm, organic feel
            period: 8 + Math.random() * 14,
            // how dormant? — the threshold below sine output where alpha = 0
            // higher = more dormant time; keeps the network sparse and surprising
            threshold: 0.15 + Math.random() * 0.25,
          });
        }
      }

      // ── Per-point screen-space displacement state (for mouse interaction) ──
      // Layout: [dx, dy, vx, vy] repeated. Float32Array keeps it fast.
      const disp = new Float32Array(points.length * 4);

      // ── Pointer state ──
      let ptrX = null, ptrY = null;
      let ptrPrevX = null, ptrPrevY = null;
      let ptrVX = 0, ptrVY = 0;

      const hero = canvas.parentElement;
      hero.addEventListener('pointermove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const nx = e.clientX - rect.left;
        const ny = e.clientY - rect.top;
        if (ptrPrevX !== null) {
          ptrVX = nx - ptrPrevX;
          ptrVY = ny - ptrPrevY;
        }
        ptrPrevX = nx;
        ptrPrevY = ny;
        ptrX = nx;
        ptrY = ny;
      }, { passive: true });

      hero.addEventListener('pointerleave', () => {
        ptrX = null; ptrY = null;
        ptrPrevX = null; ptrPrevY = null;
      });

      // ── Sizing / DPR ──
      let width = 0, height = 0, scale = 1, dpr = window.devicePixelRatio || 1;
      function resize() {
        const rect = canvas.getBoundingClientRect();
        width = rect.width;
        height = rect.height;
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        // Orb radius relative to viewport
        scale = Math.min(width, height) * 0.38;
      }
      resize();
      window.addEventListener('resize', resize);

      // ── Animation state ──
      let rotY = 0, rotX = -0.35;
      const rotYSpeed = 0.0018;   // rad per frame, very slow
      const rotXSpeed = 0.00035;  // tiny wobble on X

      // Projection focal length (higher = more orthographic, lower = more perspective)
      const FOCAL = 2.2;

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function project(p) {
        // rotate around Y
        const cosY = Math.cos(rotY), sinY = Math.sin(rotY);
        const x1 = p.x * cosY - p.z * sinY;
        const z1 = p.x * sinY + p.z * cosY;
        // rotate around X
        const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
        const y2 = p.y * cosX - z1 * sinX;
        const z2 = p.y * sinX + z1 * cosX;
        // perspective project
        const pers = FOCAL / (FOCAL - z2);
        return {
          sx: width / 2 + x1 * scale * pers,
          sy: height / 2 + y2 * scale * pers,
          z:  z2,
          pers,
        };
      }

      // Constants for pointer interaction physics
      const POINTER_RADIUS = 180;      // pixels of influence
      const POINTER_FORCE  = 0.9;      // base push strength
      const POINTER_SPEED_BOOST = 3.2; // extra push proportional to cursor speed
      const SPRING = 0.055;            // return-to-rest stiffness
      const DAMPING = 0.88;            // per-frame velocity decay
      const MAX_DISP = 80;             // clamp so points don't fly off screen

      function render() {
        // clear (transparent so CSS background shows)
        ctx.clearRect(0, 0, width, height);

        // 1. Project all points to get base (undisturbed) positions
        const proj = points.map(project);

        // 2. Update displacement physics per point
        const mouseActive = ptrX !== null && !reducedMotion;
        const speedMag = Math.sqrt(ptrVX * ptrVX + ptrVY * ptrVY);
        const speedFactor = Math.min(1.2, speedMag / 25);

        for (let i = 0; i < points.length; i++) {
          const base = proj[i];
          let dx = disp[i*4 + 0];
          let dy = disp[i*4 + 1];
          let vx = disp[i*4 + 2];
          let vy = disp[i*4 + 3];

          // Pointer repulsion (mouse pushes points away)
          if (mouseActive) {
            const mdx = base.sx - ptrX;
            const mdy = base.sy - ptrY;
            const distSq = mdx * mdx + mdy * mdy;
            if (distSq < POINTER_RADIUS * POINTER_RADIUS) {
              const dist = Math.sqrt(distSq) + 0.001;
              const falloff = 1 - dist / POINTER_RADIUS;
              const strength = falloff * falloff * (POINTER_FORCE + speedFactor * POINTER_SPEED_BOOST);
              // Direction: away from pointer, in screen space
              vx += (mdx / dist) * strength;
              vy += (mdy / dist) * strength;
              // Add a small tangential swirl so the flurry feels organic, not purely radial
              const swirl = falloff * speedFactor * 0.4;
              vx += (-mdy / dist) * swirl;
              vy += ( mdx / dist) * swirl;
            }
          }

          // Spring back toward rest (base projected position)
          vx -= dx * SPRING;
          vy -= dy * SPRING;

          // Damping (energy loss)
          vx *= DAMPING;
          vy *= DAMPING;

          // Integrate
          dx += vx;
          dy += vy;

          // Clamp (safety)
          if (dx >  MAX_DISP) dx =  MAX_DISP;
          if (dx < -MAX_DISP) dx = -MAX_DISP;
          if (dy >  MAX_DISP) dy =  MAX_DISP;
          if (dy < -MAX_DISP) dy = -MAX_DISP;

          disp[i*4 + 0] = dx;
          disp[i*4 + 1] = dy;
          disp[i*4 + 2] = vx;
          disp[i*4 + 3] = vy;

          // Apply displacement to the projected position
          base.sx += dx;
          base.sy += dy;
        }

        // Decay pointer velocity each frame (so fast movement creates a wake, then fades)
        ptrVX *= 0.72;
        ptrVY *= 0.72;

        // 3. Draw connections with per-edge pulsing lifecycle
        const time = performance.now() * 0.001;
        ctx.lineWidth = 0.6;
        for (let c = 0; c < connections.length; c++) {
          const conn = connections[c];
          const a = proj[conn.i];
          const b = proj[conn.j];

          // Per-edge cycle: sine wave offset by phase, clipped below threshold → dormant
          const raw = Math.sin(time * (Math.PI * 2 / conn.period) + conn.phase);
          let pulse = (raw - conn.threshold) / (1 - conn.threshold);
          if (pulse <= 0) continue; // dormant — don't draw
          if (pulse > 1) pulse = 1;
          // Smoothstep the edge so fades look organic
          pulse = pulse * pulse * (3 - 2 * pulse);

          // Depth-based base brightness
          const avgZ = (a.z + b.z) * 0.5;
          const depthT = (avgZ + 1) * 0.5;
          const alpha = (0.04 + depthT * 0.42) * pulse;

          if (alpha < 0.01) continue;

          ctx.strokeStyle = `rgba(246, 241, 231, ${alpha})`;
          ctx.beginPath();
          ctx.moveTo(a.sx, a.sy);
          ctx.lineTo(b.sx, b.sy);
          ctx.stroke();
        }

        // 4. Draw points (nodes)
        for (let i = 0; i < points.length; i++) {
          const p = points[i];
          const pr = proj[i];
          const t = (pr.z + 1) * 0.5;
          const radius = 1.1 + t * 1.8;
          const alpha = 0.2 + t * 0.75;
          if (p.accent) {
            ctx.fillStyle = `rgba(240, 231, 148, ${alpha})`;
            ctx.beginPath();
            ctx.arc(pr.sx, pr.sy, radius * 1.4, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = `rgba(240, 231, 148, ${Math.min(1, alpha + 0.25)})`;
            ctx.beginPath();
            ctx.arc(pr.sx, pr.sy, radius * 0.55, 0, Math.PI * 2);
            ctx.fill();
          } else {
            ctx.fillStyle = `rgba(246, 241, 231, ${alpha})`;
            ctx.beginPath();
            ctx.arc(pr.sx, pr.sy, radius, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        // 5. Advance rotation
        if (!reducedMotion) {
          rotY += rotYSpeed;
          rotX = -0.35 + Math.sin(rotY * 0.3) * 0.12;
        }
      }

      let rafId;
      function loop() {
        render();
        rafId = requestAnimationFrame(loop);
      }

      // For reduced motion: draw one static frame and stop
      if (reducedMotion) {
        render();
      } else {
        loop();
      }

      // Pause when tab is hidden (saves battery)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          if (rafId) cancelAnimationFrame(rafId);
        } else if (!reducedMotion) {
          loop();
        }
      });
    })();
  </script>

  <!-- ═════════ MISSION STATEMENT ═════════ -->
  <section class="section section-mission">
    <div class="container">
      <p class="eyebrow">What We Do</p>
      <p class="mission-statement" style="margin-top: 2rem;">
        A strategic design practice for ministry.
        <span class="accent">We listen carefully. We think structurally.</span>
        And we build things that hold up as the ground keeps shifting.
      </p>
      <p class="mission-body">
        Most ministry teams are stuck between two bad options — running on yesterday's model or chasing the latest
        framework. We work in the space between: the discipline of product design, the patience of good ministry,
        and honest conversation about what's actually happening on the ground.
      </p>
    </div>
  </section>

  <!-- ═════════ METHOD ═════════ -->
  <section class="section section-method">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">The Method</p>
        <h2 class="display-h2">Four pillars<br/>we work by.</h2>
        <p class="lead-intro">
          These are the values that shape every engagement — from a half-day canvas session with a church leadership
          team to a multi-month product partnership with a faith-tech startup.
        </p>
      </div>

      <ol class="method-list">
        <li class="method-item">
          <div class="method-num">01</div>
          <div class="method-body">
            <h3>Context Humility</h3>
            <p>Understanding the cultural context before acting. Every ministry operates within a specific context that shapes how the gospel is received. We listen before we advise.</p>
          </div>
        </li>
        <li class="method-item">
          <div class="method-num">02</div>
          <div class="method-body">
            <h3>Design Thinking</h3>
            <p>Applying human-centered design to ministry and product challenges. Starting with empathy, prototyping solutions, iterating on real feedback rather than assumptions.</p>
          </div>
        </li>
        <li class="method-item">
          <div class="method-num">03</div>
          <div class="method-body">
            <h3>Collaborative Team Work</h3>
            <p>Drawing on diverse gifts and perspectives across a team. Participatory leadership that empowers rather than controls.</p>
          </div>
        </li>
        <li class="method-item">
          <div class="method-num">04</div>
          <div class="method-body">
            <h3>Psychological Safety</h3>
            <p>Creating environments where people can take risks, admit mistakes, and grow without fear. Good work needs safe space — especially when the stakes matter.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═════════ PULL QUOTE ═════════ -->
  <section class="section section-quote">
    <div class="container">
      <blockquote class="pull-quote">
        <p>
          &ldquo;All ministry is designed —
          <span class="quote-em">whether you know it or not.&rdquo;</span>
        </p>
        <cite>Tyler Prieb · Missional Labs</cite>
      </blockquote>
      <p class="quote-rejoinder">
        Our work is helping ministries design on purpose.
      </p>
    </div>
  </section>

  <!-- ═════════ SERVICES ═════════ -->
  <section class="section section-services">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">How We Work With You</p>
        <h2 class="display-h2">Four ways<br/>to bring us in.</h2>
        <p class="lead-intro">
          Every engagement is shaped to your context — but most fit one of these four patterns. Start with whichever
          matches where you are, and we'll figure out what comes next together.
        </p>
      </div>

      <div class="services-grid">
        <article class="service-card">
          <div class="service-num">01</div>
          <h3>Ministry Consultation</h3>
          <p>Personalized consultation to help your church navigate cultural shifts, clarify missional identity, and design effective witness in fluid contexts. Typically 4–8 sessions, in-person or remote.</p>
        </article>

        <article class="service-card">
          <div class="service-num">02</div>
          <h3>Canvas Workshop Facilitation</h3>
          <p>We facilitate a Ministry Model Canvas session with your team — half-day or full-day. You leave with a shared strategic artifact, a clear target audience, and a plan for what to prototype next.</p>
        </article>

        <article class="service-card">
          <div class="service-num">03</div>
          <h3>Innovation Training</h3>
          <p>Workshops for ministry teams on applied design thinking, rapid prototyping, user research for churches, and formation-centered product development. Delivered at your site or online.</p>
        </article>

        <article class="service-card">
          <div class="service-num">04</div>
          <h3>Online Innovation Cohort</h3>
          <p>A small cohort of ministry innovators working through the frameworks together over eight weeks — peer learning, structured exercises, and expert guidance.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═════════ PROCESS ═════════ -->
  <section class="section section-process">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">How An Engagement Unfolds</p>
        <h2 class="display-h2">Listen.<br/>Map. Build. Learn.</h2>
        <p class="lead-intro">
          Every project follows a simple shape — from first conversation to shipped work. The scale varies; the rhythm
          is the same.
        </p>
      </div>

      <div class="process-steps">
        <div class="process-step">
          <div class="num">01</div>
          <h4>Listen</h4>
          <p>Conversations with leadership, staff, and the people you're trying to reach. We come in curious, not prescriptive.</p>
        </div>
        <div class="process-step">
          <div class="num">02</div>
          <h4>Map</h4>
          <p>We articulate what we've heard on a shared canvas — context, audience, missional identity, resources. One page you can point to.</p>
        </div>
        <div class="process-step">
          <div class="num">03</div>
          <h4>Build</h4>
          <p>Small, testable prototypes rather than five-year plans. A new gathering format, a redesigned communication, a product experiment.</p>
        </div>
        <div class="process-step">
          <div class="num">04</div>
          <h4>Learn</h4>
          <p>We measure what actually happened, adjust what didn't work, and hand you the tools to keep iterating after we're gone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═════════ FRAMEWORKS ═════════ -->
  <section class="section section-light">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">The Tools We Work With</p>
        <h2 class="display-h2">Frameworks,<br/>free to use.</h2>
        <p class="lead-intro">
          Our consulting draws on a body of open-source frameworks published at
          <a href="https://missional.design" target="_blank" rel="noopener noreferrer"><strong>missional.design</strong></a>.
          Read them, use them freely — or bring us in to help apply them to your context.
        </p>
      </div>

      <div class="frameworks-grid">
        <a href={`${base}/missional-by-design`} class="framework-card">
          <div class="framework-card-eyebrow">01 · Approach</div>
          <h3>Missional by Design</h3>
          <p>The underlying approach. A transformational framework for church leadership combining strategic thinking, stewardship, and participatory operations.</p>
          <span class="framework-card-link">Read the approach <span aria-hidden="true">→</span></span>
        </a>

        <a href="https://missional.design/ministry-model-canvas" target="_blank" rel="noopener noreferrer" class="framework-card">
          <div class="framework-card-eyebrow">02 · Canvas</div>
          <h3>Ministry Model Canvas</h3>
          <p>A nine-block strategic planning framework adapted from the Business Model Canvas. For clarifying target audience, missional identity, and effectiveness.</p>
          <span class="framework-card-link">Explore the canvas <span aria-hidden="true">↗</span></span>
        </a>

        <a href="https://missional.design/framework" target="_blank" rel="noopener noreferrer" class="framework-card">
          <div class="framework-card-eyebrow">03 · Product</div>
          <h3>Missional Product Design</h3>
          <p>Nine principles and six diagnostic questions for building digital tools that serve spiritual formation rather than engagement optimization.</p>
          <span class="framework-card-link">Read the framework <span aria-hidden="true">↗</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═════════ FINAL CTA ═════════ -->
  <section class="section section-cta">
    <div class="container">
      <p class="eyebrow">Let's Work Together</p>
      <h2 class="cta-title">Something<br/>you're building?</h2>
      <p class="cta-sub">
        If you're a church, ministry, or faith-driven team working on something new — or trying to reshape something
        old — we'd love to hear about it. First conversations are free and unhurried.
      </p>
      <a href={`${base}/about`} class="cta-button">Get in touch</a>
    </div>
  </section>
</BaseLayout>
